<resources>
    <style name="Theme.StudentFlow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/studentflow_primary</item>
        <item name="colorPrimaryDark">@color/studentflow_primary_dark</item>
        <item name="colorSecondary">@color/studentflow_accent</item>
        <item name="android:colorAccent">@color/studentflow_accent</item>
        <item name="android:windowBackground">@color/studentflow_primary</item>
        <item name="android:navigationBarColor">@color/studentflow_surface</item>
        <item name="android:statusBarColor">@color/studentflow_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:windowAnimationStyle">@style/StudentFlow.ActivityAnimation</item>
    </style>

    <style name="StudentFlow.ActivityAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/sf_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/sf_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/sf_pop_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/sf_pop_exit</item>
        <item name="android:taskOpenEnterAnimation">@anim/sf_enter</item>
        <item name="android:taskOpenExitAnimation">@anim/sf_exit</item>
        <item name="android:taskCloseEnterAnimation">@anim/sf_pop_enter</item>
        <item name="android:taskCloseExitAnimation">@anim/sf_pop_exit</item>
    </style>

    <style name="StudentFlow.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/studentflow_field</item>
        <item name="boxStrokeColor">@color/studentflow_border_active</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintTextColor">@color/studentflow_text_muted</item>
        <item name="android:textColorHint">@color/studentflow_text_muted</item>
    </style>

    <style name="StudentFlow.AuthToggle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/studentflow_border_active</item>
        <item name="android:textColor">@color/studentflow_primary</item>
        <item name="backgroundTint">@color/studentflow_field</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="StudentFlow.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/studentflow_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="StudentFlow.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/studentflow_border</item>
        <item name="android:textColor">@color/studentflow_primary</item>
        <item name="backgroundTint">@color/studentflow_field</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">48dp</item>
    </style>
</resources>
